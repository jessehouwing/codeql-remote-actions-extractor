{
  "name": "jessehouwing.codeql-remote-actions-extractor",
  "description": "GitHub Action to download remote composite actions and callable workflows for CodeQL analysis",
  "version": "1.0.0",
  "author": "Jesse Houwing",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/jessehouwing/codeql-remote-actions-extractor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jessehouwing/codeql-remote-actions-extractor.git"
  },
  "bugs": {
    "url": "https://github.com/jessehouwing/codeql-remote-actions-extractor/issues"
  },
  "keywords": [
    "actions",
    "codeql"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "npx --node-options=--experimental-vm-modules jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "npx --node-options=--experimental-vm-modules jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@octokit/core": "^7.0.6",
    "dockerfile-ast": "^0.7.1",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.3",
    "prettier-eslint": "^16.4.2",
    "rollup": "^4.60.3",
    "ts-jest": "^29.4.9",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.3"
  }
}
